{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Tablo",
  "scopeName": "source.tablo",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#properties"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tablo",
          "begin": "//",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.tablo"
            }
          },
          "end": "$\\n?"
        },
        {
          "name": "comment.block.tablo",
          "begin": "/\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.tablo"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.tablo"
            }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.tablo",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.declaration.tablo",
          "begin": "\\b(fn)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.declaration.function.tablo"
            },
            "3": {
              "name": "entity.name.function.tablo"
            }
          },
          "end": "(?=\\{)",
          "patterns": [
            {
              "include": "#types"
            },
            {
              "include": "#operators"
            },
            {
              "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s*:)",
              "captures": {
                "1": {
                  "name": "variable.parameter.tablo"
                }
              }
            }
          ]
        },
        {
          "name": "meta.function.call.tablo",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.tablo"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tablo",
          "match": "\\b(?:if|else|while|for|in|break|continue|return)\\b"
        },
        {
          "name": "keyword.control.database.tablo",
          "match": "\\b(?:with|find|first|last|count|where|order|by|asc|desc|create|update|delete|transaction|commit|rollback)\\b"
        },
        {
          "name": "keyword.declaration.tablo",
          "match": "\\b(?:var|const|rec|mut|obj|pub)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.tablo",
          "match": "\\b\\d(?:[\\d_]*\\d)?\\.\\d(?:[\\d_]*\\d)?\\b"
        },
        {
          "name": "constant.numeric.integer.tablo",
          "match": "\\b\\d(?:[\\d_]*\\d)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.tablo",
          "match": "(?<![<>!=+\\-*/%&|^])(?:=|\\+=|-=|\\*=|/=|%=)"
        },
        {
          "name": "keyword.operator.comparison.tablo",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.tablo",
          "match": "&&|\\|\\||\\^|!"
        },
        {
          "name": "keyword.operator.arithmetic.tablo",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.reference.tablo",
          "match": "&"
        },
        {
          "name": "keyword.operator.range.tablo",
          "match": ":"
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "variable.other.property.tablo",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "support.type.object-field.tablo",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s*:)",
          "captures": {
            "1": {
              "name": "variable.other.member.tablo"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.tablo",
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.tablo"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.tablo"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.tablo",
              "match": "\\\\(?:['\\\\nrt])"
            }
          ]
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.tablo",
          "match": "\\b(?:int|dec|text|bool|void)\\b"
        },
        {
          "name": "storage.type.object.tablo",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
